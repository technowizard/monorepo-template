{
  "name": "@monorepo-template/server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "predev": "pnpm db:migrate",
    "dev": "tsx watch src/index.ts",
    "build": "tsdown",
    "start": "node dist/index.mjs",
    "db:generate": "drizzle-kit generate --config src/config/drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config src/config/drizzle.config.ts",
    "db:push": "drizzle-kit push --config src/config/drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config src/config/drizzle.config.ts",
    "db:migrate:test": "tsx scripts/migrate-test.ts",
    "typecheck": "tsc --noEmit",
    "test": "cross-env NODE_ENV=test vitest"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.7",
    "@hono/zod-openapi": "^1.1.5",
    "@scalar/hono-api-reference": "^0.9.28",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.44.7",
    "drizzle-zod": "^0.8.3",
    "hono": "catalog:",
    "hono-pino": "^0.10.3",
    "hono-rate-limiter": "^0.5.3",
    "pg": "^8.16.3",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.3",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@monorepo-template/config": "workspace:*",
    "@types/jsdom": "^27.0.0",
    "@types/node": "catalog:",
    "@types/pg": "^8.16.0",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.8",
    "prettier": "^3.8.0",
    "tsdown": "0.21.7",
    "tsx": "^4.21.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
